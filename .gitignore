# The notebook series' shared roofline tally is a generated, per-run artifact.
python/notebooks/scoreboard.json

# Transient outputs of collect_board_data.py / a board run. The canonical copies
# we keep as a baseline live in python/reference_data/ under stable names.
/board_data.json
/scoreboard.json

